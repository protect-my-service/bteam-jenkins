# Required
JENKINS_ADMIN_PASSWORD=change-me-please

# Optional (비우면 기본값 또는 빈 credential로 기동)
GITHUB_PAT=
SLACK_TOKEN=
JENKINS_URL=http://localhost:8080/

# Linux only — `getent group docker | cut -d: -f3`
DOCKER_GID=999

# -----------------------------------------------------------------------------
# Production (AWS Spot) 전용 — .env에 직접 넣지 말고 SSM Parameter Store에 저장.
# user-data가 IMDS 토큰으로 받아와 /etc/jenkins.env에 작성한 뒤 docker compose에서
# 동일한 키로 로드되도록 한다. 자세한 절차는 infra/aws-setup.md 참고.
# -----------------------------------------------------------------------------
# JENKINS_URL=https://jenkins.example.com/
# AGENT_SECRET_1=<Manage Nodes → linux-agent-1 → secret 값>
